# 本地或 CI/CD 运行 Terraform 时，把这个文件复制成 secrets.auto.tfvars 后再填真实值。
# 这个文件不提交仓库，适合放敏感信息和环境运行时镜像参数。

sql_administrator_login_password = "ChangeMe-Testbed-Sql-Password-123!"
sql_connection_string            = "Server=tcp:docflow-testbed-sql.database.windows.net,1433;Initial Catalog=DocFlowCloudTestbedDb;Persist Security Info=False;User ID=docflowadmin;Password=ChangeMe;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
blob_connection_string           = "DefaultEndpointsProtocol=https;AccountName=stgdocflowtestbed;AccountKey=ChangeMe;EndpointSuffix=core.windows.net"
service_bus_connection_string    = "Endpoint=sb://sb-docflow-testbed.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=ChangeMe"
ghcr_registry_username           = "ChangeMe-GitHub-Username"
ghcr_registry_password           = "ChangeMe-GHCR-Read-Token"

api_image          = "ghcr.io/example/docflowcloud-api:testbed-latest"
web_image          = "ghcr.io/example/docflowcloud-web:testbed-latest"
worker_image       = "ghcr.io/example/docflowcloud-worker:testbed-latest"
notification_image = "ghcr.io/example/docflowcloud-notification-service:testbed-latest"
migrator_image     = "ghcr.io/example/docflowcloud-migrator:testbed-latest"
